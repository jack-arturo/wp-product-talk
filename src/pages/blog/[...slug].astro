---
import Layout from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateStr = new Date(post.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${post.data.title} · WP Product Talk`} description={post.data.description}>
  <!-- Post Header -->
  <section style="background: linear-gradient(180deg, #0c1220 0%, #0f172a 100%); border-bottom: 1px solid #1e293b;" class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-xs font-medium mb-6 transition-colors duration-150"
        style="color: #64748b;"
        onmouseover="this.style.color='#f59e0b'"
        onmouseout="this.style.color='#64748b'"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to Blog
      </a>

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {post.data.tags.map((tag: string) => (
            <span
              class="text-xs font-medium px-2.5 py-1 rounded-full"
              style="background-color: #f59e0b15; color: #f59e0b; border: 1px solid #f59e0b30;"
            >
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4" style="color: #f1f5f9;">
        {post.data.title}
      </h1>

      <p class="text-base leading-relaxed mb-4" style="color: #94a3b8;">
        {post.data.description}
      </p>

      <time class="text-sm" style="color: #64748b;">{dateStr}</time>
    </div>
  </section>

  <!-- Post Content -->
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="prose prose-invert prose-amber max-w-none">
      <Content />
    </div>
  </article>

  <!-- Navigation -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="flex items-center justify-between pt-8" style="border-top: 1px solid #1e293b;">
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-sm font-medium transition-colors duration-150"
        style="color: #64748b;"
        onmouseover="this.style.color='#f59e0b'"
        onmouseout="this.style.color='#64748b'"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        All Posts
      </a>
      <a
        href="/episodes"
        class="inline-flex items-center gap-1.5 text-sm font-medium transition-colors duration-150"
        style="color: #64748b;"
        onmouseover="this.style.color='#f59e0b'"
        onmouseout="this.style.color='#64748b'"
      >
        Browse Episodes
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>
