---
interface Props {
  name: string;
  role: string;
  bio: string;
  imageUrl?: string;
  initials?: string;
}

const { name, role, bio, imageUrl, initials } = Astro.props;
---

<div
  class="flex flex-col items-center text-center p-6 rounded-2xl"
  style="background-color: #1e293b; border: 1px solid #334155;"
>
  <!-- Avatar -->
  <div class="mb-4">
    {imageUrl ? (
      <img
        src={imageUrl}
        alt={name}
        class="w-20 h-20 rounded-full object-cover"
        style="border: 3px solid #f59e0b;"
        loading="lazy"
      />
    ) : (
      <div
        class="w-20 h-20 rounded-full flex items-center justify-center text-2xl font-bold"
        style="background: linear-gradient(135deg, #1e3a5f 0%, #1e293b 100%); border: 3px solid #f59e0b; color: #f59e0b;"
      >
        {initials || name.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
      </div>
    )}
  </div>

  <!-- Name -->
  <h3 class="font-bold text-lg mb-1" style="color: #f1f5f9;">{name}</h3>

  <!-- Role -->
  <p class="text-sm font-medium mb-3" style="color: #f59e0b;">{role}</p>

  <!-- Bio -->
  <p class="text-sm leading-relaxed" style="color: #94a3b8;">{bio}</p>
</div>
